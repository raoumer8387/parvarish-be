# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/parvarish_db

# Google Gemini (AI Studio key — if set, used instead of OpenRouter)
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
# Gemini output length (ignored when using OpenRouter without Google key)
GEMINI_MAX_OUTPUT_TOKENS=4096

# OpenRouter (only if GOOGLE_API_KEY is not set)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENROUTER_MODEL=qwen/qwen3-30b-a3b-instruct-2507
OPENROUTER_VISION_MODEL=google/gemini-2.5-pro
# On HTTP 429 (free-tier throttling): retries with backoff (defaults 3 retries, 2s base delay).
# OPENROUTER_RATE_LIMIT_RETRIES=5
# OPENROUTER_RATE_LIMIT_DELAY_SEC=2
# Max completion tokens (default 976). Increase only if your OpenRouter budget allows (truncation if too low).
# OPENROUTER_MAX_TOKENS=2048
# Optional: Hugging Face token — higher rate limits when loading sentence-transformers / embeddings.
# HF_TOKEN=
# Optional: PDF parsing engine when sending PDFs (cloudflare-ai | mistral-ocr | native)
# OPENROUTER_PDF_ENGINE=cloudflare-ai

# Voice Transcription Configuration (OpenAI-compatible speech-to-text)
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_LANGUAGE=

# JWT Configuration (NEW)
# Generate secure secret: [System.Web.Security.Membership]::GeneratePassword(64,10)
JWT_SECRET=your-super-secret-random-string-at-least-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=24

# Google OAuth Configuration (NEW)
# Get this from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
